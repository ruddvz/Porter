# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini AI
GEMINI_API_KEY=

# Meta WhatsApp Cloud API — webhook verify handshake (GET hub.verify_token)
# Must match Meta → WhatsApp → Configuration → Webhook → Verify token.
# Optional alias: META_VERIFY_TOKEN (same value) for docs/tools that use that name.
META_WEBHOOK_VERIFY_TOKEN=porter_verify_2024
# META_VERIFY_TOKEN=

# Optional: dev-only global Meta token/phone (production uses per-seller columns on `sellers`)
# META_WHATSAPP_TOKEN=
# META_PHONE_NUMBER_ID=

# Razorpay (server webhook signature)
RAZORPAY_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Cron (abandoned conversation nudges)
CRON_SECRET=

# Note: Per-seller Meta phone_number_id, access token, and Razorpay keys live in the `sellers` table.
