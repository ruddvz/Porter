# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: show Google OAuth on login/signup when Google is enabled in Supabase Auth
# and redirect URLs include `{NEXT_PUBLIC_APP_URL}/auth/callback`.
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=

# Gemini AI
GEMINI_API_KEY=

# Meta WhatsApp Cloud API — webhook verify handshake (GET hub.verify_token)
# Must match Meta → WhatsApp → Configuration → Webhook → Verify token.
# Optional alias: META_VERIFY_TOKEN (same value) for docs/tools that use that name.
META_WEBHOOK_VERIFY_TOKEN=porter_verify_2024
# META_VERIFY_TOKEN=

# Optional: dev-only global Meta token/phone (production uses per-seller columns on `sellers`)
# META_WHATSAPP_TOKEN=
# META_PHONE_NUMBER_ID=

# Razorpay (server webhook signature)
RAZORPAY_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Cron (abandoned conversation nudges)
CRON_SECRET=

# Optional: encrypt UPI / Razorpay at rest after save (server)
PORTER_CREDENTIAL_SECRET=

# Web Push (VAPID) — run: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Shared secret for /api/push/send (server-to-server)
PUSH_INTERNAL_SECRET=
