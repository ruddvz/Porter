# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini AI
GEMINI_API_KEY=

# Meta WhatsApp — webhook verify (GET). Optional alias META_VERIFY_TOKEN.
META_WEBHOOK_VERIFY_TOKEN=porter_verify_2024

# Razorpay (server webhook signature)
RAZORPAY_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Cron (abandoned conversation nudges)
CRON_SECRET=

# Optional: encrypt UPI / Razorpay at rest after save (server)
PORTER_CREDENTIAL_SECRET=

# Web Push (VAPID) — run: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Shared secret for /api/push/send (server-to-server)
PUSH_INTERNAL_SECRET=
