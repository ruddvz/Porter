          ]
        }
      ],
      "acceptance_criteria": [
        "Seller can see simple business impact.",
        "No vanity metrics only.",
        "Top products and low stock are actionable."
      ]
    },
    {
      "id": "admin_sellers",
      "name": "Admin Sellers",
      "route": "/admin/sellers",
      "goal": "Let Porter team onboard and support stores.",
