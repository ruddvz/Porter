  "data_model": {
    "tables": [
      "stores",
      "categories",
      "products",
      "product_variants",
      "inventory_locations",
      "inventory_balances",
      "inventory_movements",
      "orders",
      "order_items",
      "stock_reservations",
      "customers",
      "payment_events",
      "website_widgets",
      "whatsapp_conversations"
    ],
    "inventory_logic": {
      "available": "on_hand - reserved",
      "order_placed": "create stock_reservation and increase reserved",
      "order_completed": "decrease on_hand and reserved; mark reservation fulfilled",
      "order_cancelled": "decrease reserved; mark reservation released",
      "manual_stock_change": "create inventory_movement"
    }
  },
  "implementation_sequence": [
